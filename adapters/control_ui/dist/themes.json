{
  "$schema": "https://hydragent.ai/schemas/control-ui/themes.json",
  "default": "hydra-dark",
  "themes": [
    {
      "id": "hydra-dark",
      "label": "Hydra Dark",
      "type": "dark",
      "vars": {
        "--hydra-bg": "#070b12",
        "--hydra-bg-elev": "rgba(15, 22, 36, 0.72)",
        "--hydra-bg-soft": "rgba(22, 32, 50, 0.55)",
        "--hydra-fg": "#e4ecf6",
        "--hydra-fg-muted": "#8a9bb5",
        "--hydra-accent": "#38bdf8",
        "--hydra-accent-2": "#22d3ee",
        "--hydra-accent-soft": "rgba(56, 189, 248, 0.18)",
        "--hydra-glow": "rgba(34, 211, 238, 0.35)",
        "--hydra-border": "rgba(148, 163, 184, 0.14)",
        "--hydra-shadow": "0 10px 40px rgba(0, 0, 0, 0.55)"
      }
    },
    {
      "id": "hydra-light",
      "label": "Hydra Light",
      "type": "light",
      "vars": {
        "--hydra-bg": "#f4f7fb",
        "--hydra-bg-elev": "rgba(255, 255, 255, 0.85)",
        "--hydra-bg-soft": "rgba(238, 244, 252, 0.7)",
        "--hydra-fg": "#0b1220",
        "--hydra-fg-muted": "#5a6a82",
        "--hydra-accent": "#0284c7",
        "--hydra-accent-2": "#0891b2",
        "--hydra-accent-soft": "rgba(2, 132, 199, 0.12)",
        "--hydra-glow": "rgba(8, 145, 178, 0.25)",
        "--hydra-border": "rgba(15, 23, 42, 0.10)",
        "--hydra-shadow": "0 8px 30px rgba(20, 30, 50, 0.10)"
      }
    },
    {
      "id": "abyss",
      "label": "Abyss",
      "type": "dark",
      "vars": {
        "--hydra-bg": "radial-gradient(ellipse at top, #0a0b2a 0%, #02030a 60%)",
        "--hydra-bg-elev": "rgba(11, 16, 36, 0.78)",
        "--hydra-bg-soft": "rgba(20, 27, 58, 0.55)",
        "--hydra-fg": "#c8c4ff",
        "--hydra-fg-muted": "#7a7eb0",
        "--hydra-accent": "#a78bfa",
        "--hydra-accent-2": "#f472b6",
        "--hydra-accent-soft": "rgba(167, 139, 250, 0.18)",
        "--hydra-glow": "rgba(244, 114, 182, 0.30)",
        "--hydra-border": "rgba(167, 139, 250, 0.18)",
        "--hydra-shadow": "0 12px 48px rgba(0, 0, 0, 0.65)"
      }
    },
    {
      "id": "aurora",
      "label": "Aurora",
      "type": "dark",
      "vars": {
        "--hydra-bg": "linear-gradient(135deg, #0a1430 0%, #1c0b30 55%, #0b3022 100%)",
        "--hydra-bg-elev": "rgba(20, 30, 50, 0.55)",
        "--hydra-bg-soft": "rgba(20, 30, 50, 0.30)",
        "--hydra-fg": "#f1f3ff",
        "--hydra-fg-muted": "#b6c1da",
        "--hydra-accent": "#76e4c1",
        "--hydra-accent-2": "#a78bfa",
        "--hydra-accent-soft": "rgba(118, 228, 193, 0.18)",
        "--hydra-glow": "rgba(167, 139, 250, 0.30)",
        "--hydra-border": "rgba(255, 255, 255, 0.10)",
        "--hydra-shadow": "0 12px 48px rgba(0, 0, 0, 0.5)"
      }
    }
  ]
}
