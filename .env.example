# ── The "Brain" (the agent's single live LLM) ────────────────────────────
# The agent has one swappable brain. Set these four vars to point at any
# OpenAI-compatible /v1/chat/completions endpoint:
#
#   BRAIN_BASE     = Base URL (no trailing slash)
#   BRAIN_KEY      = API key (empty for local providers like Ollama)
#   BRAIN_MODEL    = Primary model
#   BRAIN_FALLBACKS= Comma-separated fallback models (tried in order)
#
# Examples:
#   OpenRouter:    BRAIN_BASE=https://openrouter.ai/api/v1
#   OpenAI:        BRAIN_BASE=https://api.openai.com/v1
#   Together AI:   BRAIN_BASE=https://api.together.xyz/v1
#   Groq:          BRAIN_BASE=https://api.groq.com/openai/v1
#   Fireworks:     BRAIN_BASE=https://api.fireworks.ai/inference/v1
#   Ollama:        BRAIN_BASE=http://localhost:11434/v1   (BRAIN_KEY can be empty)
#   LM Studio:     BRAIN_BASE=http://localhost:1234/v1
#   vLLM / TGI:    BRAIN_BASE=http://localhost:8000/v1
#
# Backward compat: if you leave BRAIN_BASE empty but set OPENROUTER_API_KEYS,
# the agent auto-uses https://openrouter.ai/api/v1.

BRAIN_BASE=https://openrouter.ai/api/v1
BRAIN_KEY=your-key-here
BRAIN_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
BRAIN_FALLBACKS=openai/gpt-oss-120b:free,moonshotai/kimi-k2.6:free


# ── Data Paths ─────────────────────────────────────────────────────────────
DATA_DIR=./data

# ── Runtime Tuning ─────────────────────────────────────────────────────────
# Maximum ReAct loop steps before giving up
MAX_REACT_STEPS=10

# ── Logging ────────────────────────────────────────────────────────────────
# Options: debug, info, warn, error
LOG_LEVEL=warn
# Options: json, terminal
LOG_FORMAT=terminal

# ── Telegram Adapter ────────────────────────────────────────────────────────
# Your Telegram Bot token obtained from @BotFather (quotes not required)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Comma-separated list of whitelisted Telegram Chat IDs authorized to talk to the bot
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ── Telegram Mini App Configuration ──────────────────────────────────────────
# Set to "pyngrok" to automatically start a tunnel, or paste a custom HTTPS URL.
TELEGRAM_WEBAPP_URL=pyngrok
