# ── LLM Providers ─────────────────────────────────────────────────────────
# Comma-separated list of keys for automatic rate limit rotation
OPENROUTER_API_KEYS=your-openrouter-key-here
# Optional: local Ollama instance (Phase 1 stub)
OLLAMA_URL=http://localhost:11434


# ── Data Paths ─────────────────────────────────────────────────────────────
DATA_DIR=./data

# ── Runtime Tuning ─────────────────────────────────────────────────────────
PRIMARY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Fallback models (comma-separated, tried in order)
FALLBACK_MODELS=openai/gpt-oss-120b:free,moonshotai/kimi-k2.6:free
# Maximum ReAct loop steps before giving up
MAX_REACT_STEPS=10

# ── Logging ────────────────────────────────────────────────────────────────
# Options: debug, info, warn, error
LOG_LEVEL=warn
# Options: json, terminal
LOG_FORMAT=terminal

# ── Telegram Adapter ────────────────────────────────────────────────────────
# Your Telegram Bot token obtained from @BotFather (quotes not required)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Comma-separated list of whitelisted Telegram Chat IDs authorized to talk to the bot
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ── Telegram Mini App Configuration ──────────────────────────────────────────
# Set to "pyngrok" to automatically start a tunnel, or paste a custom HTTPS URL.
TELEGRAM_WEBAPP_URL=pyngrok
# Your ngrok auth token from dashboard.ngrok.com (optional but recommended for persistent sessions)
NGROK_AUTH_TOKEN=""
# The local port for the Mini App dashboard web server
MINIAPP_PORT=5001



