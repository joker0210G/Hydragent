# ------------------------------------------------------------------------
# Hydragent configuration (v0.7.1)
#
# Copy this file to .env and fill in the values you need.
#   cp .env.example .env
# Or just run `.\Hydragent.cmd onboard` (Windows) / `hydragent onboard`
# (Unix) and answer the wizard — it writes a .env for you.
#
# Quick map:
#   REQUIRED for first chat:   BRAIN_BASE, BRAIN_KEY, BRAIN_MODEL
#   OPTIONAL:                  BRAIN_FALLBACKS, DATA_DIR, MAX_REACT_STEPS,
#                              LOG_*, HYDRAGENT_*, TELEGRAM_*, DISCORD_*,
#                              SLACK_*, EMAIL_*, WEBHOOK_*
#   OPTIONAL until vault-on:   HYDRAGENT_VAULT_PASSPHRASE
# ------------------------------------------------------------------------


# --- The "Brain" (the agent's single live LLM) --------------------------------------
# The agent has one swappable brain. Set these four vars to point at any
# OpenAI-compatible /v1/chat/completions endpoint.
#
# === Common pitfalls (READ THESE) =====================================
# 1. NO TRAILING SLASH on BRAIN_BASE.
#      CORRECT: BRAIN_BASE=https://openrouter.ai/api/v1
#      WRONG:   BRAIN_BASE=https://openrouter.ai/api/v1/
#    The kernel appends "/chat/completions" itself. A trailing slash
#    produces "//chat/completions" and you'll get a 404 / 401.
#
# 2. BRAIN_KEY can be empty for local providers.
#    Ollama and LM Studio don't require auth — leave BRAIN_KEY blank.
#    OpenRouter / OpenAI / Together / Groq require a real key.
#
# 3. BRAIN_FALLBACKS are tried in order, serially, on any brain error.
#    Cheapest / fastest first is usually a good rule of thumb.
#    The chain stops at the first model that returns successfully.
#
# 4. Reasoning models vs chat models.
#    Models that emit <think>…</think> blocks (DeepSeek R1, QwQ,
#    Anthropic extended-thinking, Mistral Magistral) work with the
#    reasoning detector and HYDRAGENT_SHOW_REASONING=1 toggles the
#    dim "thought" line in `hydragent chat`. Pure chat models
#    (MiniMax-M3, GPT-4o, Claude Sonnet 4, Gemini 2.5 Flash) emit
#    no reasoning blocks — that's normal, not a bug. The detector
#    is a no-op for them.
# =====================================================================
#
# Provider examples:
#   OpenRouter:    BRAIN_BASE=https://openrouter.ai/api/v1
#   OpenAI:        BRAIN_BASE=https://api.openai.com/v1
#   Together AI:   BRAIN_BASE=https://api.together.xyz/v1
#   Groq:          BRAIN_BASE=https://api.groq.com/openai/v1
#   Fireworks:     BRAIN_BASE=https://api.fireworks.ai/inference/v1
#   Ollama:        BRAIN_BASE=http://localhost:11434/v1   (BRAIN_KEY can be empty)
#   LM Studio:     BRAIN_BASE=http://localhost:1234/v1    (BRAIN_KEY can be empty)
#   vLLM / TGI:    BRAIN_BASE=http://localhost:8000/v1    (BRAIN_KEY can be empty)

BRAIN_BASE=https://openrouter.ai/api/v1
BRAIN_KEY=your-key-here
# Pick whatever model your provider offers. Some examples:
#   OpenRouter free:  nvidia/nemotron-3-ultra-550b-a55b:free
#   OpenAI:           openai/gpt-4o-mini
#   Anthropic:        anthropic/claude-3-5-haiku
#   Local:            qwen2.5-coder:7b  (Ollama tag)
BRAIN_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Comma-separated. Tried in order, stops at first success.
# Tip: list cheap / fast models first, expensive reasoning models last.
BRAIN_FALLBACKS=openai/gpt-oss-120b:free,moonshotai/kimi-k2.6:free


# --- Legacy aliases (still supported) --------------------------------------------
# If both the new BRAIN_* name and the legacy name are set, BRAIN_* wins.
#   OPENROUTER_API_KEYS  <->  BRAIN_KEY
#   PRIMARY_MODEL        <->  BRAIN_MODEL
#   FALLBACK_MODELS      <->  BRAIN_FALLBACKS
# If you leave BRAIN_BASE empty but set OPENROUTER_API_KEYS, the agent
# auto-uses https://openrouter.ai/api/v1 for backwards compatibility.


# --- Data Paths ------------------------------------------------------------
# Where the vault, skill library, audit log, and models live.
# Default is fine for local dev. Use an absolute path for services.
DATA_DIR=./data


# --- Encrypted vault (Phase 3 — OPTIONAL) --------------------------------------
# Only required if you enable vault encryption. Leave UNSET for the
# default unencrypted local vault (fine for solo dev).
# When set, the vault is encrypted at rest with XChaCha20-Poly1305,
# and the key is derived from this passphrase via Argon2id.
#   HYDRAGENT_VAULT_PASSPHRASE=<your-secure-local-passphrase>


# --- Runtime Tuning --------------------------------------------------------
# Maximum ReAct loop steps before giving up. Higher = more autonomy,
# more tokens, more chance of drift. 10 is the default; 4-6 is enough
# for most tool-augmented Q&A.
MAX_REACT_STEPS=10

# --- Logging ---------------------------------------------------------------
# Global log level for the kernel and crates.
# Options: debug, info, warn, error
LOG_LEVEL=warn
# Format: json (machine-readable) or terminal (coloured, with symbols).
LOG_FORMAT=terminal
# Chat REPL log level — overrides LOG_LEVEL for `hydragent chat` only.
# Default is "error" so chat output is clean. Set to "info" or "debug"
# to see what the kernel is doing under the hood.
#   HYDRAGENT_CHAT_LOG=error|warn|info|debug

# --- Reasoning trace (v0.7.1) --------------------------------------------------
# When set to 1, `hydragent chat` prints the model's hidden reasoning
# block in dim grey below each turn. Has no effect on chat models that
# don't emit reasoning (MiniMax-M3, GPT-4o, Claude Sonnet 4, etc.).
#   HYDRAGENT_SHOW_REASONING=1


# --- Channel adapters (Python, OPTIONAL — only if you run that adapter) --------------------
# Each token is independent. Leave any of them blank if you don't use
# that channel. The adapters are in adapters/<name>_adapter.py.

# --- Telegram ---------------------------------------------------------------
# Your Telegram Bot token obtained from @BotFather. No quotes.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Comma-separated list of whitelisted Telegram Chat IDs. Leave empty
# to reject all inbound messages (safe default for an unused token).
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# Set to "pyngrok" to auto-tunnel the Mini App, or paste an HTTPS URL.
TELEGRAM_WEBAPP_URL=pyngrok

# --- Discord ---------------------------------------------------------------
#   DISCORD_BOT_TOKEN=your-discord-bot-token-here
#   DISCORD_ALLOWED_GUILD_IDS=123456789012345678
#   DISCORD_ALLOWED_CHANNEL_IDS=987654321098765432

# --- Slack -----------------------------------------------------------------
#   SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
#   SLACK_ALLOWED_CHANNEL_IDS=C01234567,C89012345

# --- Email -----------------------------------------------------------------
#   EMAIL_IMAP_HOST=imap.gmail.com
#   EMAIL_IMAP_PORT=993
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_PORT=587
#   EMAIL_USERNAME=you@gmail.com
#   EMAIL_PASSWORD=your-app-password     # use a Gmail app password, not your real one
#   EMAIL_ALLOWED_FROM_ADDRESSES=alice@example.com,bob@example.com

# --- Webhook --------------------------------------------------------------
#   WEBHOOK_PORT=8765
#   WEBHOOK_SHARED_SECRET=random-string-shared-with-the-sender

# --- WebSocket (the bus itself is on TCP 127.0.0.1:5000) --------------------------------
# The bus is local-only by default. No env var needed for the default.
# To expose it (NOT recommended without a reverse proxy + auth):
#   HYDRA_BUS_BIND=0.0.0.0:5000
